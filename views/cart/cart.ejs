<% layout("/layouts/boilerplate") -%>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<div class="cart-page mt-4 mb-5">
  <div class="cart-breadcrumb mb-4">
    <a href="/listings">Home</a>
    <span>›</span>
    <span>Cart</span>
  </div>

  <% const price = listing.price; %>

  <div class="row g-4 align-items-stretch">
    <div class="col-12 col-lg-8">
      <div class="cart-panel">
        <div class="table-responsive">
          <table class="table align-middle cart-table mb-0">
            <thead>
              <tr>
                <th scope="col">Product</th>
                <th scope="col">Price</th>
                <th scope="col">Dates</th>
                <th scope="col">Subtotal</th>
                <th scope="col"></th>
              </tr>
            </thead>
            <tbody>
              <tr class="cart-item-row" data-day-price="<%= price %>">
                <td>
                  <div class="d-flex align-items-center gap-3">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="cart-item-img" />
                    <div>
                      <a href="/listings/<%= listing._id %>" class="cart-item-title"><%= listing.title %></a>
                      <div class="cart-item-meta"><%= listing.location %>, <%= listing.country %></div>
                    </div>
                  </div>
                </td>
                <td class="cart-price-cell">৳<%= price.toLocaleString("en-BN") %></td>
                <td>
                  <div class="cart-date-group">
                    <input
                      type="text"
                      class="form-control cart-date-input"
                      id="booking-range"
                      placeholder="Select check-in and check-out"
                      aria-label="Booking date range"
                    />
                    <div class="cart-date-meta text-muted small">
                      <span data-days-value>1</span> night(s)
                    </div>
                    <div class="text-danger small" data-date-error hidden>
                      Please select available dates.
                    </div>
                  </div>
                </td>
                <td class="cart-subtotal-cell">৳<%= price.toLocaleString("en-BN") %></td>
                <td>
                  <a href="/listings/<%= listing._id %>" class="cart-remove" title="Remove from cart">
                    <i class="fa-solid fa-trash-can"></i>
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="cart-actions"></div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="cart-summary">
        <h5 class="cart-summary-title">Order Details</h5>

        <div class="cart-summary-row">
          <span>Sub Total</span>
          <strong data-summary-subtotal>৳<%= price.toLocaleString("en-BN") %></strong>
        </div>
        <div class="cart-summary-row">
          <span>GST (18%)</span>
          <strong data-summary-gst>৳0</strong>
        </div>
        <div class="cart-summary-row" data-summary-usd-row hidden>
          <span>Total (USD)</span>
          <strong data-summary-usd>$0</strong>
        </div>
        <div class="cart-summary-row" data-summary-local-row hidden>
          <span data-summary-local-label>Approx. Total (Local)</span>
          <strong data-summary-local>0</strong>
        </div>
        <div class="cart-summary-row total-row">
          <span>Total Amount</span>
          <strong data-summary-total>৳<%= price.toLocaleString("en-BN") %></strong>
        </div>

        <div class="cart-summary-rate" data-summary-rate hidden>
          Rate: 1 USD = <span data-summary-rate-value>0</span>
        </div>

        <button class="btn cart-pay-btn w-100" type="button" data-pay-button onclick="makePayment()">
          Pay ৳<%= price.toLocaleString("en-BN") %>
        </button>
        <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary w-100 cart-back-btn">Back to Listing</a>
        <p class="cart-disclaimer">
          You will be charged in USD. Local currency totals are approximate.
        </p>
      </div>
    </div>
  </div>
</div>

<script id="cart-listing-data" type="application/json"><%- JSON.stringify(listing) %></script>
<script id="cart-booking-ranges" type="application/json"><%- JSON.stringify(bookingRanges || []) %></script>
<script id="cart-config-data" type="application/json"><%- JSON.stringify({
  apiURL: "/cart",
  stripePublicKey: process.env.WANDERLUST_STRIPE_PUBLIC_KEY || ""
}) %></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script type="module" src="/js/cart.js"></script>