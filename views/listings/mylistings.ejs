<% layout("/layouts/boilerplate") -%>

<div class="container mt-5 mb-5">
  <%
    const formatNumber = (value) => Number(value || 0).toLocaleString(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });
  %>
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h2 class="mb-1">My Listings</h2>
      <p class="text-muted mb-0">Listings created from your account.</p>
    </div>
    <a href="/listings/new" class="btn btn-outline-dark">Create Listing</a>
  </div>

  <% if (allListings.length === 0) { %>
    <div class="alert alert-light border">You have not created any listings yet.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-bordered align-middle">
        <thead class="table-light">
          <tr>
            <th>Listing</th>
            <th>Location</th>
            <th>Price</th>
            <th>Orders</th>
            <th>Total Revenue</th>
            <th>Booking Status</th>
            <th>Listing Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% allListings.forEach(function(listing) { %>
            <tr>
                        <td><span class="nowrap"><%= listing.listingName %></span></td>
              <td>
                <span class="nowrap"><%= listing.location || "Location unavailable" %></span>
              </td>
                        <td><span class="nowrap">&#2547; <%= listing.price.toLocaleString("en-BN") %> /night</span></td>
                        <td><%= listing.totalOrders || 0 %></td>
              <td>
                          <% if (listing.totalOrders > 0 && listing.totalPaid > 0) { %>
                  <% const currencyLabel = listing.totalPaidCurrency === "MULTI" ? "Multiple" : (listing.totalPaidCurrency || ""); %>
                  <span class="total-revenue"><%= currencyLabel ? `${currencyLabel} ${formatNumber(listing.totalPaid)}` : formatNumber(listing.totalPaid) %></span>
                <% } else { %>
                  <span class="text-muted">N/A</span>
                <% } %>
              </td>
              <td>
                <% if (listing.status === "inactive") { %>
                  <span class="badge badge-unknown">Unknown</span>
                <% } else if (listing.bookingRange) { %>
                  <span class="badge booked-badge">Booked</span>
                <% } else { %>
                  <span class="badge text-bg-secondary">Not booked</span>
                <% } %>
              </td>
                        <td>
                                    <% if (listing.status === "maintenance") { %>
                                      <span class="badge text-bg-warning">Maintenance</span>
                                    <% } else if (listing.status === "inactive") { %>
                            <span class="badge deleted-status-badge">Deleted</span>
                          <% } else { %>
                            <span class="badge status-active-badge">Active</span>
                          <% } %>
                        </td>
              <td>
                <div class="d-flex align-items-center gap-1 flex-nowrap reservation-actions">
                            <a href="/listings/<%= listing.listingId %>" class="btn btn-sm btn-outline-dark">View</a>
                  <a href="/listings/mylistings/<%= listing.listingId %>/orders" class="btn btn-sm btn-outline-dark">Orders</a>
                            <% if (listing.status === "active") { %>
                              <form action="/listings/mylistings/<%= listing.listingId %>/maintenance" method="post" class="m-0">
                                <button class="btn btn-sm btn-outline-danger">Maintenance</button>
                              </form>
                            <% } else { %>
                              <form action="/listings/mylistings/<%= listing.listingId %>/active" method="post" class="m-0">
                                <button class="btn btn-sm btn-outline-success">Active</button>
                              </form>
                            <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
