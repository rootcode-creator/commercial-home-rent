<% layout("/layouts/boilerplate") -%>

<%
  const formatMoney = (value, currency) => {
    const amount = Number(value || 0);
    const code = String(currency || "BDT").toUpperCase();
    return amount.toLocaleString("en-US", { style: "currency", currency: code });
  };

  const getInclusiveBookingDays = (order) => {
    const startRaw = order && (order.bookingStartDate || order.reservationDate);
    const endRaw = order && order.bookingEndDate;
    if (!startRaw || !endRaw) {
      return Math.max(1, Number(order && order.bookingDays) || 1);
    }

    const start = new Date(startRaw);
    const end = new Date(endRaw);
    if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
      return Math.max(1, Number(order && order.bookingDays) || 1);
    }

    const toUtcDay = (date) => Date.UTC(date.getFullYear(), date.getMonth(), date.getDate());
    const diff = Math.round((toUtcDay(end) - toUtcDay(start)) / (24 * 60 * 60 * 1000));
    return Math.max(1, diff + 1);
  };

  const getBookingDateRange = (order) => {
    const startRaw = order && (order.bookingStartDate || order.reservationDate);
    const endRaw = order && order.bookingEndDate;

    if (!startRaw) {
      return "N/A";
    }

    const start = new Date(startRaw);
    if (Number.isNaN(start.getTime())) {
      return "N/A";
    }

    const formatDate = (date) =>
      date
        .toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "2-digit" })
        .replace(/([A-Za-z]+)/, (match) => match.toUpperCase());

    const startText = formatDate(start);

    if (!endRaw) {
      return startText;
    }

    const end = new Date(endRaw);
    if (Number.isNaN(end.getTime())) {
      return startText;
    }

    return `${startText} - ${formatDate(end)}`;
  };
%>

<div class="container mt-5 mb-5">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h2 class="mb-1">Orders for <%= listing.title %></h2>
      <p class="text-muted mb-0"><%= listing.location %></p>
    </div>
    <a href="/listings/mylistings" class="btn btn-outline-dark">Back to My Listings</a>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-light border">No orders for this listing yet.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-bordered align-middle">
        <thead class="table-light">
          <tr>
            <th>Customer</th>
            <th>Email</th>
            <th>Booking Dates</th>
            <th>Booked For</th>
            <th>Amount</th>
            <th>Paid At</th>
            <th>Payment Status</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order) { %>
            <tr>
              <td><%= order.customerName || "Guest" %></td>
              <td><%= order.customerEmail || "N/A" %></td>
              <td><%= getBookingDateRange(order) %></td>
              <td><%= getInclusiveBookingDays(order) %> day(s)</td>
              <td>
                <% const amountValue = order.localAmountTotal ?? order.amountTotal ?? 0; %>
                <% const currency = order.localCurrency || order.currency || "BDT"; %>
                <%= formatMoney(amountValue, currency) %>
              </td>
              <td><%= order.reservationDate ? new Date(order.reservationDate).toLocaleString() : "N/A" %></td>
              <td>
                <% if (String(order.status || "").toLowerCase() === "paid") { %>
                  <span class="badge text-bg-success">Paid</span>
                <% } else if (String(order.status || "").toLowerCase() === "failed") { %>
                  <span class="badge text-bg-danger">Failed</span>
                <% } else { %>
                  <span class="badge text-bg-secondary"><%= order.status || "Unknown" %></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
