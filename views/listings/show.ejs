<% layout("/layouts/boilerplate") -%>

<script>
 const mapToken = "<%= process.env.MAP_TOKEN %>";
 const listing = <%- JSON.stringify(listing) %>;

</script>

  <div class="listing-show">
    <div class="listing-header">
      <h3>
        <%= listing.title %>
      </h3>
    </div>

    <div class="listing-gallery">
      <div class="gallery-main">
        <img src="<%= listing.image.url %>" class="gallery-img" alt="listing image" />
      </div>
      <div class="gallery-side">
        <img src="<%= listing.image.url %>" class="gallery-img" alt="listing image" />
        <img src="<%= listing.image.url %>" class="gallery-img" alt="listing image" />
        <img src="<%= listing.image.url %>" class="gallery-img" alt="listing image" />
        <img src="<%= listing.image.url %>" class="gallery-img" alt="listing image" />
      </div>
    </div>

    <div class="listing-content">
      <div class="listing-primary">
        <div class="card listing-summary">
          <div class="card-body">
            <div class="listing-host">
              <div class="listing-host-avatar">
                <% if (listing.owner && listing.owner.avatar && listing.owner.avatar.url) { %>
                  <img src="<%= listing.owner.avatar.url %>" alt="Profile" class="listing-host-avatar-image" />
                <% } else { %>
                  <%= (listing.owner.username || "U").charAt(0).toUpperCase() %>
                <% } %>
              </div>
              <p class="card-text mb-0">
                Owned by <b><i><%= listing.owner.username %></i></b>
              </p>
            </div>

            <div class="listing-divider"></div>

            <p class="card-text">
              <i class="fa-solid fa-audio-description"></i> &nbsp; <%= listing.description %>
            </p>
            <p class="card-text">
              <i class="fa-solid fa-location-dot"></i> &nbsp; <%= listing.location %>
            </p>

            <p class="card-text">
              <i class="fa-solid fa-flag"></i> &nbsp;<%= listing.country %>
            </p>
          </div>
        </div>

        <% if (currUser && listing.owner._id.equals(currUser._id) ){ %>

        <div class="btns mb-5">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 small-screen">Edit</a>

          <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark offset-5 del-btn small-screen">Delete</button>
          </form>
        </div>


        <% } %>

      </div>

      <aside class="listing-aside">
        <div class="card listing-booking">
          <div class="card-body">
            <p class="card-text listing-price">
              &#2547; &nbsp; <%= listing.price.toLocaleString("en-BN") %> /night
            </p>
            <% if (currUser && !listing.owner._id.equals(currUser._id)) { %>
              <a href="/cart/<%= listing._id %>" class="btn payment-btn w-100 mt-2">
                Reserve
              </a>
            <% } %>
          </div>
        </div>
      </aside>
    </div>

    <% const canReview = currUser && !listing.owner._id.equals(currUser._id); %>
    <div class="listing-reviews-section <%= canReview ? "" : "no-form" %>">
      <div class="reviews-layout <%= canReview ? "" : "no-form" %>">
        <% if (canReview){ %>
        <div class="reviews-form">
          <h4>Leave a Review</h4>
          <form action="/listings/<%= listing.id %>/reviews" method="post" class="needs-validation" novalidate>
           

            <div class="mb-3 mt-3">
              <div class="rating-row">
                <label for="rating" class="form-label mb-0">Rating</label>

                <fieldset class="starability-slot">
              
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
              </div>

            </div>

            <div class="mb-3 mt-3">
              <label for="comment" class="form-label">Comments</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
              <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
          </form>
        </div>
        <% } %>

        <div class="reviews-list">
          <% const reviews = listing.reviews || []; %>
          <% if (reviews.length > 0) {%>
            <div class="listing-reviews">
              <% const avgRating = reviews.length ? (reviews.reduce((sum, r) => sum + (r.rating || 0), 0) / reviews.length) : 0; %>
              <% const avgStars = Math.round(avgRating); %>
              <div class="reviews-summary">
                <h4 class="reviews-summary-title">All Reviews</h4>
              </div>

              <div class="reviews-average-block">
                <div class="reviews-metric reviews-metric-avg">
                  <div class="reviews-metric-value"><%= avgRating.toFixed(2) %></div>
                  <p class="starability-result" data-rating="<%= avgStars %>"></p>
                </div>
                <div class="reviews-metric reviews-metric-avg reviews-metric-count">
                  <div class="reviews-metric-value"><%= reviews.length %></div>
                  <div class="reviews-metric-label">Reviews</div>
                </div>
              </div>

            <div class="reviews-grid">
              <% for(review of reviews){ %>
                <% const reviewDate = review.createdAt ? new Date(review.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) : ""; %>
                <% const joinedAt = review.author && review.author.joinedAt ? new Date(review.author.joinedAt) : null; %>
                <% const yearsOn = joinedAt ? Math.max(1, Math.floor((Date.now() - joinedAt.getTime()) / 31557600000)) : null; %>
                <div class="review-item">
                  <div class="review-head">
                    <div class="review-avatar">
                      <% if (review.author && review.author.avatar && review.author.avatar.url) { %>
                        <img src="<%= review.author.avatar.url %>" alt="Profile" class="review-avatar-image" />
                      <% } else { %>
                        <%= (review.author.username || "U").charAt(0).toUpperCase() %>
                      <% } %>
                    </div>
                    <div>
                      <h5 class="card-title review-name">@<%= review.author.username %></h5>
                      <% if (review.author && review.author.city) { %>
                        <p class="review-subtitle mb-0"><%= review.author.city %></p>
                      <% } %>
                      <% if (yearsOn) { %>
                        <p class="review-subtitle mb-0"><%= yearsOn %> years on Home Rent</p>
                      <% } %>
                      <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                      <% if (reviewDate) { %>
                        <p class="review-date mb-0"><%= reviewDate %></p>
                      <% } %>
                    </div>
                  </div>

                  <p class="card-text mb-3"><%= review.comment %></p>

                  <% if (currUser && review.author && review.author._id && review.author._id.equals(currUser._id)) { %>
                  <form class="mb-3" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="post">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
          <% } else { %>
          <div class="listing-reviews is-empty">
            <div class="reviews-summary">
              <h4 class="reviews-summary-title">All Reviews</h4>
            </div>
            <div class="listing-empty-section mb-3">
              <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
                <p class="text-muted mb-0">No reviews yet.</p>
              <% } else { %>
                <p class="text-muted mb-0">No reviews yet. Be the first to share your experience by log in.</p>
              <% } %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="listing-map">
      <h3>Where you'll be</h3>
      <div id="map"></div>
    </div>
  </div>

 <script src="/js/map.js"></script>