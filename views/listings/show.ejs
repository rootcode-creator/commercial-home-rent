<script>
  // Open overlay for full comment without changing card height
  (function(){
    document.addEventListener('click', function(e){
      const t = e.target;
      if (!t) return;
      if (t.classList.contains('show-more-link')){
        e.preventDefault();
        const parent = t.closest('.review-item');
        if (!parent) return;
        const overlay = parent.querySelector('.review-overlay');
        if (!overlay) return;
        overlay.style.display = 'flex';
        overlay.setAttribute('aria-hidden','false');
      }
      if (t.classList.contains('overlay-close')){
        e.preventDefault();
        const overlay = t.closest('.review-overlay');
        if (!overlay) return;
        overlay.style.display = 'none';
        overlay.setAttribute('aria-hidden','true');
      }
    });
  })();
</script>