<% layout('/layouts/boilerplate') -%>

<%
  const formatNumber = (value) => Number(value || 0).toLocaleString(undefined, {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });

  const formatUsd = (value) => Number(value || 0).toLocaleString('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });

  const getDisplayUsdAmount = (record) => {
    const usd = Number(record && record.usdAmountTotal);
    const base = Number(record && record.amountTotal);
    const originalCurrency = String((record && record.originalCurrency) || (record && record.localCurrency) || '').toUpperCase();

    if (Number.isFinite(usd)) {
      if (Number.isFinite(base) && Math.abs(usd - (base * 100)) < 0.001) {
        return base;
      }
      const usdIsWhole = Math.abs(usd - Math.trunc(usd)) < 0.000001;
      if (usdIsWhole && usd >= 1000 && originalCurrency && originalCurrency !== 'USD') {
        return usd / 100;
      }
      return usd;
    }

    if (String((record && record.currency) || '').toUpperCase() === 'USD' && Number.isFinite(base)) {
      const baseIsWhole = Math.abs(base - Math.trunc(base)) < 0.000001;
      if (baseIsWhole && base >= 1000 && originalCurrency && originalCurrency !== 'USD') {
        return base / 100;
      }
      return base;
    }

    return null;
  };

  const formatShortDate = (value) => {
    if (!value) return "";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";
    return date
      .toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "2-digit" })
      .replace(/([A-Za-z]+)/, (match) => match.toUpperCase());
  };

  const getInclusiveBookingDays = (record) => {
    const startRaw = record && (record.bookingStartDate || record.reservationDate);
    const endRaw = record && record.bookingEndDate;
    if (!startRaw || !endRaw) {
      return Math.max(1, Number(record && record.bookingDays) || 1);
    }

    const start = new Date(startRaw);
    const end = new Date(endRaw);
    if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
      return Math.max(1, Number(record && record.bookingDays) || 1);
    }

    const toUtcDay = (date) => Date.UTC(date.getFullYear(), date.getMonth(), date.getDate());
    const diff = Math.round((toUtcDay(end) - toUtcDay(start)) / (24 * 60 * 60 * 1000));
    return Math.max(1, diff + 1);
  };
%>

<div class="container mt-5 mb-5 print-area receipt-page">
  <style>
    /* Print stylesheet: hide everything except .print-area */
    @media print {
      body * { visibility: hidden; }
      .print-area, .print-area * { visibility: visible; }
      .print-area { position: absolute; left: 0; top: 0; width: 100%; padding: 12mm; }
      .no-print { display: none !important; }
    }

    .receipt-page {
      max-width: 980px;
      color: #111827;
    }

    .receipt-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .receipt-brand {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .receipt-logo {
      width: 32px;
      height: 32px;
      object-fit: contain;
    }

    .receipt-title {
      font-size: 1.6rem;
      font-weight: 700;
      margin: 0;
    }

    .receipt-company {
      font-weight: 700;
      font-size: 0.95rem;
      margin-top: 0.1rem;
    }

    .receipt-thankyou {
      color: #6b7280;
      font-size: 0.9rem;
      margin-top: 0.25rem;
    }

    .receipt-meta {
      text-align: right;
      font-size: 0.9rem;
      color: #6b7280;
      width: 100%;
    }

    .receipt-table thead th {
      background: #f3f4f6;
      font-size: 0.85rem;
      text-transform: none;
    }

    .receipt-table td,
    .receipt-table th {
      border-color: #d1d5db !important;
    }

    .receipt-summary {
      min-width: 220px;
    }

    .receipt-total-row {
      background: #f3f4f6;
      font-weight: 700;
    }

    @media (max-width: 767.98px) {
      .receipt-header {
        flex-direction: column;
        gap: 1rem;
      }

      .receipt-meta {
        text-align: left;
        width: 100%;
      }

      .receipt-meta .d-flex {
        flex-direction: column !important;
        align-items: flex-start !important;
      }

      .receipt-title {
        font-size: 1.3rem;
      }

      .receipt-table {
        font-size: 0.9rem;
      }
    }
  </style>
  <div class="receipt-header">
    <div class="receipt-brand">
      <img src="<%= 'http://' + host %>/images/favicon.png" alt="Wanderlust logo" class="receipt-logo" />
      <div>
        <p class="receipt-title">Invoice</p>
        <div class="receipt-company">Wanderlust Private Limited</div>
      </div>
    </div>
    <div class="receipt-meta">
      <div class="d-flex flex-column align-items-end">
        <div class="d-flex gap-2 mb-2 no-print">
          <a href="/listings/reservations" class="btn btn-outline-dark">Back to Reservations</a>
          <a href="/listings/reservations/<%= record.sessionId %>/pdf" class="btn btn-outline-secondary">Download PDF</a>
        </div>
        <div>Website: <%= host %></div>
      </div>
    </div>
  </div>

  <div class="row mb-3 g-3">
    <div class="col-12 col-md-6">
      <h6 class="mb-1">Invoice To</h6>
      <div><strong><%= record.customerName || 'Guest' %></strong></div>
      <div><%= record.customerEmail || '—' %></div>
      <div class="text-muted"><%= (listing && listing.location) || record.listingLocation || '' %> <% if ((listing && listing.country) || record.listingCountry) { %>, <%= (listing && listing.country) || record.listingCountry %><% } %></div>
    </div>
    <div class="col-12 col-md-6 text-md-end">
      <div><strong>Invoice #</strong> <%= String((record && record.sessionId) || (record && record.paymentIntentId) || '').slice(0, 12) %></div>
      <div class="text-muted"><strong>Date:</strong> <%= formatShortDate((record && record.reservationDate) ? record.reservationDate : ((record && record.sessionCreatedAt) ? record.sessionCreatedAt : new Date())) %></div>
      <div class="text-muted"><strong>Booked For:</strong> <%= getInclusiveBookingDays(record) %> day(s)</div>
    </div>
  </div>

  <div class="table-responsive mb-3">
    <table class="table table-bordered receipt-table">
      <thead>
        <tr>
          <th style="width:60px;">SL</th>
          <th>Item Description</th>
          <th style="width:120px; text-align:right;">Price</th>
          <th style="width:90px; text-align:center;">Days</th>
          <th style="width:140px; text-align:right;">Total</th>
        </tr>
      </thead>
      <tbody>
        <% const qty = Number(getInclusiveBookingDays(record)); %>
        <% const totalLocal = Number((record && (record.originalAmountTotal !== undefined && record.originalAmountTotal !== null ? record.originalAmountTotal : (record.localAmountTotal !== undefined && record.localAmountTotal !== null ? record.localAmountTotal : record.amountTotal))) || 0); %>
        <% const unitLocal = qty > 0 ? (totalLocal / qty) : totalLocal; %>
        <tr>
          <td>1</td>
          <td>
            <div><strong><span class="nowrap"><%= (listing && listing.title) || record.listingTitle || 'Booked listing' %></span></strong></div>
          </td>
          <td style="text-align:right;"><%= formatNumber(unitLocal) %> <%= (record.originalCurrency || record.localCurrency || record.currency || '') %></td>
          <td style="text-align:center;"><%= qty %></td>
          <td style="text-align:right;"><%= formatNumber(totalLocal) %> <%= (record.originalCurrency || record.localCurrency || record.currency || '') %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="row">
    <div class="col-6">
      <div class="mb-3">
        <strong>Payment Method</strong>
        <div class="text-muted"><%= (record.paymentMethodTypes && record.paymentMethodTypes.join(', ')) || 'N/A' %></div>
      </div>
      <div>
        <strong>Customer Email</strong>
        <div class="text-muted"><%= record.customerEmail || 'N/A' %></div>
      </div>
    </div>
    <div class="col-6">
      <table class="table table-borderless receipt-summary">
        <tr>
          <td class="text-muted">Subtotal</td>
          <td class="text-end"><%= formatNumber(totalLocal) %> <%= (record.originalCurrency || record.localCurrency || record.currency || '') %></td>
        </tr>
        <tr>
          <td class="text-muted">Taxes</td>
          <td class="text-end">0.00%</td>
        </tr>
        <tr>
          <td class="text-muted">Discount</td>
          <td class="text-end">0.00%</td>
        </tr>
        <tr class="receipt-total-row">
          <td><strong>Total</strong></td>
          <td class="text-end"><strong><%= formatNumber(totalLocal) %> <%= (record.originalCurrency || record.localCurrency || record.currency || '') %></strong></td>
        </tr>
      </table>
      <% const usdAmount = getDisplayUsdAmount(record); %>
      <div class="text-end small text-muted">Equivalent USD: <% if (usdAmount !== null && usdAmount !== undefined) { %> <%= formatUsd(usdAmount) %> <% } else { %> N/A <% } %></div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-6">
      <p class="mb-1">Terms & Conditions / Notes</p>
    </div>
    <div class="col-6 text-end">
      <div style="height:60px; width:220px; margin-left:auto;">
        <img src="<%= 'http://' + host %>/images/signature.png" alt="Company signature" style="height:60px; width:auto; display:block; margin-left:auto;" />
      </div>
      <div class="small text-muted">Wanderlust Private Limited</div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12 text-center small text-muted">
      <div>Contact: info@wanderlust.com • +1 (212) 555-0123</div>
      <div>Address: 123 Wanderlust Ave, New York, NY 10001, USA</div>
    </div>
  </div>
</div>
