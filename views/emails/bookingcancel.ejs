<div style="font-family: Arial, sans-serif; color: #111; line-height:1.5; max-width:680px; margin:0 auto; padding:20px;">
  <div style="text-align:center; padding-bottom:12px;">
    <img src="<%= logoUrl %>" alt="Wanderlust" style="height:48px;"/>
  </div>
  <h2 style="color:#15803d; margin-top:0;">Hi <%= customerName || 'Guest' %>, your booking has been canceled</h2>
  <p style="margin:8px 0;">Your reservation was canceled successfully. If you have any questions, reply to <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>.</p>

  <table style="width:100%; border-collapse:collapse; margin:18px 0;">
    <tr>
      <td style="padding:8px 0; vertical-align:top; width:65%;">
        <strong><%= listingTitle %></strong><br/>
        <span style="color:#555;"><%= listingLocation %><% if (listingCountry) { %>, <%= listingCountry %><% } %></span>
      </td>
      <td style="padding:8px 0; text-align:right; vertical-align:top;">
        <strong><%= currency %> <%= total %></strong>
      </td>
    </tr>
  </table>

  <table style="width:100%; border-collapse:collapse; margin-bottom:18px;">
    <tr>
      <td style="padding:6px 0; color:#333;"><strong>Booking ID</strong></td>
      <td style="padding:6px 0; text-align:right; color:#333;"><%= bookingId %></td>
    </tr>
    <tr>
      <td style="padding:6px 0; color:#333;"><strong>Booking dates</strong></td>
      <td style="padding:6px 0; text-align:right; color:#333;">
        <%= bookingStartDate %><% if (bookingEndDate) { %> - <%= bookingEndDate %><% } %>
      </td>
    </tr>
    <tr>
      <td style="padding:6px 0; color:#333;"><strong>Nights</strong></td>
      <td style="padding:6px 0; text-align:right; color:#333;"><%= bookingDays %></td>
    </tr>
    <tr>
      <td style="padding:6px 0; color:#333;"><strong>Canceled at</strong></td>
      <td style="padding:6px 0; text-align:right; color:#333;"><%= canceledAt %></td>
    </tr>
  </table>

  <div style="background:#dcfce7; border-radius:6px; padding:12px; margin-bottom:18px; border:1px solid #86efac;">
    <strong style="color:#15803d;">Cancellation completed</strong>
    <p style="margin:8px 0 0 0; color:#14532d;">Your booking record has been canceled and no further charges will be made.</p>
  </div>

  <p style="margin:8px 0;">You can browse other listings here: <a href="/listings">/listings</a>.</p>

  <p style="margin:16px 0 0 0; color:#555;">Thanks,<br/>Wanderlust Private Limited</p>

  <hr style="margin:20px 0; border:none; border-top:1px solid #eee;"/>
  <p style="font-size:12px; color:#999; margin:0;">If you believe this was sent in error, contact <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>. This is an automated message; please do not reply to this address.</p>
</div>