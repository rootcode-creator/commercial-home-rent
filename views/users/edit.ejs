<% layout("/layouts/boilerplate") -%>

<div class="row mt-3 mb-5">
  <h1 class="col-10 offset-1 mt-3">Edit Profile</h1>
  <div class="col-10 offset-1 profile-edit">
    <form action="/users/profile/edit" method="post" class="needs-validation profile-edit-form" enctype="multipart/form-data" novalidate>
      <div class="mb-3">
        <label for="displayName" class="form-label">Name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          class="form-control"
          value="<%= user.displayName || "" %>"
          placeholder="Enter your name"
          minlength="2"
          maxlength="50"
          required
        >
        <div class="invalid-feedback">Name must be 2-50 characters.</div>
      </div>

      <div class="mb-3">
        <label for="bio" class="form-label">About / Bio</label>
        <textarea id="bio" name="bio" cols="30" rows="4" class="form-control" maxlength="1000" placeholder="Tell guests about yourself"><%= user.bio || "" %></textarea>
        <div class="form-text">Optional — up to 1000 characters.</div>
      </div>

      <div class="mb-4">
        <label for="profileImage" class="form-label">Profile Picture</label>
        <input
          type="file"
          id="profileImage"
          name="profile[image]"
          class="form-control"
          accept="image/*"
        >
        <div class="form-text">Optional — upload to change your avatar.</div>
      </div>

      <button class="btn btn-success">Save Changes</button>
    </form>

    <div class="profile-edit-preview">
      <div style="display: flex; gap: 2rem; align-items: flex-start;">
        <% if (user && user.avatar && user.avatar.url) { %>
        <div class="text-center">
          <p class="form-label mb-2">Current Image</p>
          <img src="<%= user.avatar.url %>" alt="Profile" style="width:140px;height:140px;object-fit:cover;border-radius:8px;" />
        </div>
        <% } %>
        
        <div id="previewContainer" class="text-center" style="visibility: hidden; height: 140px;">
          <p class="form-label mb-2">Preview</p>
          <img id="previewImage" src="" alt="Preview" style="width:140px;height:140px;object-fit:cover;border-radius:8px;" />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const profileImageInput = document.getElementById('profileImage');
  const previewContainer = document.getElementById('previewContainer');
  const previewImage = document.getElementById('previewImage');

  profileImageInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(event) {
        previewImage.src = event.target.result;
        previewContainer.style.visibility = 'visible';
      };
      reader.readAsDataURL(file);
    } else {
      previewContainer.style.visibility = 'hidden';
    }
  });
</script>
