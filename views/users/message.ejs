<% layout("/layouts/boilerplate") -%>

<div class="row mt-4 mb-5">
  <div class="col-10 offset-1">
    <div class="card">
      <div class="card-body">
        <h2>Message <%= host.displayName || host.username || 'Host' %></h2>
        <p class="text-muted">This messaging feature is coming soon. For now, you can contact the host via their listed contact methods.</p>
        <p>If you'd like, return to the listing or send an email to <strong><%= host.email ? host.email : 'not available' %></strong>.</p>
        <div class="mt-3">
          <a href="/listings" class="btn btn-outline-secondary">Back to listings</a>
          <a href="/users/<%= host._id %>" class="btn btn-dark">View host profile</a>
        </div>
      </div>
    </div>
  </div>
</div>
